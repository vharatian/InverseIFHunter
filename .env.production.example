# Model Hunter — PRODUCTION (root URL on http://VM_IP/ — unchanged)
# Copy to .env.production. Deploy: ./deploy.sh production
#
# Forwards /staging on :80 to the staging stack (Docker network modelhunter_edge).

ENV_NAME=production
PROJECT_NAME=mh-production
ENV_FILE=.env.production

DOMAIN=34.28.88.135
EDGE_PATH_PREFIX=/
GRAFANA_PATH_PREFIX=/grafana
GRAFANA_ROOT_URL=http://34.28.88.135/grafana/

# Load Traefik file provider: proxy /staging → staging-traefik-gateway
TRAEFIK_DYNAMIC_DIR=./traefik/dynamic-bridge

# World-facing HTTP entry (trainers + staging path)
TRAEFIK_HOST_PORTMAP=80:80

TRAEFIK_HTTP_PORT=80
ELIXIR_PORT=4000
PYTHON_PORT=8000
DASHBOARD_PORT=8001
PG_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

PG_USER=mh
PG_PASSWORD=CHANGE_ME_strong_production_password
PG_DATABASE=model_hunter
DATABASE_URL=postgresql+asyncpg://mh:CHANGE_ME_strong_production_password@postgres:5432/model_hunter

REDIS_URL=redis://redis:6379/0

ELIXIR_SECRET_KEY_BASE=CHANGE_ME_generate_with_mix_phx_gen_secret

ADMIN_PASSWORD=CHANGE_ME_production_admin

GRAFANA_PASSWORD=CHANGE_ME_production_grafana

# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
