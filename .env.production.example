# Model Hunter — PRODUCTION Environment Variables
# Copy to .env.production and fill in real values.
# Deploy with: ./deploy.sh production

# === Environment ===
ENV_NAME=production
PROJECT_NAME=mh-production
# Used by docker-compose.prod.yml (python-core env_file)
ENV_FILE=.env.production

# === Domain ===
DOMAIN=your-domain.example.com
ACME_EMAIL=admin@example.com

# === Ports (host-side, bound to 127.0.0.1) ===
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
ELIXIR_PORT=4000
PYTHON_PORT=8000
DASHBOARD_PORT=8001
PG_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# === API Keys ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
# FIREWORKS_API_KEY=your-fireworks-key

# === PostgreSQL ===
PG_USER=mh
PG_PASSWORD=CHANGE_ME_strong_production_password
PG_DATABASE=model_hunter
DATABASE_URL=postgresql+asyncpg://mh:CHANGE_ME_strong_production_password@postgres:5432/model_hunter

# === Redis (DB 0) ===
REDIS_URL=redis://redis:6379/0

# === Elixir ===
ELIXIR_SECRET_KEY_BASE=CHANGE_ME_generate_with_mix_phx_gen_secret

# === Dashboard ===
ADMIN_PASSWORD=CHANGE_ME_production_admin

# === Grafana ===
GRAFANA_PASSWORD=CHANGE_ME_production_grafana

# === Optional ===
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
