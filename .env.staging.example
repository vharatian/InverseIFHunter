# Model Hunter — STAGING (same VM as production, public URL http://VM_IP/staging)
# Copy to .env.staging. Deploy: ./deploy.sh staging
#
# Production must use TRAEFIK_DYNAMIC_DIR=./traefik/dynamic-bridge and publish Traefik on :80.
# Trainers use port 80 only; staging Traefik stays on loopback for debugging.

ENV_NAME=staging
PROJECT_NAME=mh-staging
ENV_FILE=.env.staging

# DOMAIN: public IP or hostname — used by Phoenix (PHX_HOST) and links. Traefik rules here use PathPrefix (see overrides).
# Do not leave EDGE_PATH_PREFIX / GRAFANA_PATH_PREFIX blank (empty PathPrefix breaks Traefik).
DOMAIN=34.28.88.135

# Path-based staging (required for /staging on production Traefik)
STAGING_COMPOSE_OVERRIDE=1
EDGE_PATH_PREFIX=/staging
GRAFANA_PATH_PREFIX=/staging/grafana
EDGE_STRIP_PREFIX=/staging

# Links Phoenix/Grafana generate (port 80 = production Traefik entry)
PUBLIC_HTTP_PORT=80
GRAFANA_ROOT_URL=http://34.28.88.135/staging/grafana/

# Staging Traefik: 127.0.0.1:8080→80 in docker-compose.staging-overrides.yml (base compose has no Traefik host ports).

# No bridge file on staging Traefik (production serves /staging → here)
TRAEFIK_DYNAMIC_DIR=./traefik/dynamic-noop

ELIXIR_PORT=4010
PYTHON_PORT=8010
DASHBOARD_PORT=8011
PG_PORT=5433
REDIS_PORT=6380
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

PG_USER=mh_staging
PG_PASSWORD=CHANGE_ME_staging_password
PG_DATABASE=model_hunter_staging
DATABASE_URL=postgresql+asyncpg://mh_staging:CHANGE_ME_staging_password@postgres:5432/model_hunter_staging

REDIS_URL=redis://redis:6379/1

ELIXIR_SECRET_KEY_BASE=CHANGE_ME_staging_secret_64_chars_minimum_generate_with_mix_phx_gen_secret

ADMIN_PASSWORD=CHANGE_ME_staging_admin

GRAFANA_PASSWORD=CHANGE_ME_staging_grafana

# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
