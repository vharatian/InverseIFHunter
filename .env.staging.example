# Model Hunter — STAGING (same VM as production, public URL http://VM_IP/staging)
# Copy to .env.staging. Deploy: ./deploy.sh staging
#
# Public access is via PRODUCTION port 80 (not :8080): http://DOMAIN/staging/ and /staging/grafana/
# Production must run ./deploy.sh production (nginx edge) for those URLs to work.
#
# Dashboard live feed: docker-compose.prod.yml mounts shared Docker volumes so python-core (trainer/reviewer)
# and python-dashboard read the same TELEMETRY_LOG_PATH (/app/.telemetry/events.jsonl). No extra env vars
# are required for that. After changing compose volumes, recreate containers (e.g. deploy.sh staging) so
# mounts apply. Verify: docker compose exec python-core ls -la /app/.telemetry and same in python-dashboard.

ENV_NAME=staging
PROJECT_NAME=mh-staging
ENV_FILE=.env.staging

# DOMAIN: public IP or hostname — used by Phoenix (PHX_HOST) and links.
DOMAIN=34.28.88.135

# Registers mh-edge aliases (staging-edge-gateway, staging-grafana-gateway) for production nginx.
STAGING_COMPOSE_OVERRIDE=1
# Optional documentation-only (URLs in docs / operator checklist):
EDGE_PATH_PREFIX=/staging
GRAFANA_PATH_PREFIX=/staging/grafana

# Links Phoenix/Grafana generate (port 80 = production nginx)
PUBLIC_HTTP_PORT=80
GRAFANA_ROOT_URL=http://34.28.88.135/staging/grafana/

ELIXIR_PORT=4010
PYTHON_PORT=8010
DASHBOARD_PORT=8011
PG_PORT=5433
REDIS_PORT=6380
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001

OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

PG_USER=mh_staging
PG_PASSWORD=CHANGE_ME_staging_password
PG_DATABASE=model_hunter_staging
DATABASE_URL=postgresql+asyncpg://mh_staging:CHANGE_ME_staging_password@postgres:5432/model_hunter_staging

REDIS_URL=redis://redis:6379/1

ELIXIR_SECRET_KEY_BASE=CHANGE_ME_staging_secret_64_chars_minimum_generate_with_mix_phx_gen_secret

ADMIN_PASSWORD=CHANGE_ME_staging_admin

GRAFANA_PASSWORD=CHANGE_ME_staging_grafana

# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
