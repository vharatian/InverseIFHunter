# Model Hunter — STAGING Environment Variables
# Copy to .env.staging and fill in values.
# Deploy with: ./deploy.sh staging

# === Environment ===
ENV_NAME=staging
PROJECT_NAME=mh-staging
ENV_FILE=.env.staging

# === Traefik / paths ===
# DOMAIN: hostname or IP only — never http:// or path segments (Traefik Host()).
#
# A) Subdomain + HTTPS (Let's Encrypt) — typical:
DOMAIN=staging.your-domain.example.com
EDGE_PATH_PREFIX=/
GRAFANA_PATH_PREFIX=/grafana
GRAFANA_ROOT_URL=https://staging.your-domain.example.com/grafana/
#
# B) Same IP as prod with path prefix + HTTP-only Traefik (use second compose file):
# STAGING_COMPOSE_OVERRIDE=1
# DOMAIN=34.28.88.135
# EDGE_PATH_PREFIX=/staging
# GRAFANA_PATH_PREFIX=/staging/grafana
# EDGE_STRIP_PREFIX=/staging
# GRAFANA_ROOT_URL=http://34.28.88.135:8080/staging/grafana/
# TRAEFIK_HTTP_PORT=8080

ACME_EMAIL=admin@example.com

# === Ports (host-side, bound to 127.0.0.1) ===
TRAEFIK_HTTP_PORT=8080
TRAEFIK_HTTPS_PORT=8443
ELIXIR_PORT=4010
PYTHON_PORT=8010
DASHBOARD_PORT=8011
PG_PORT=5433
REDIS_PORT=6380
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001

# === API Keys ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# === PostgreSQL ===
PG_USER=mh_staging
PG_PASSWORD=CHANGE_ME_staging_password
PG_DATABASE=model_hunter_staging
DATABASE_URL=postgresql+asyncpg://mh_staging:CHANGE_ME_staging_password@postgres:5432/model_hunter_staging

# === Redis (DB 1 — production uses DB 0) ===
REDIS_URL=redis://redis:6379/1

# === Elixir ===
ELIXIR_SECRET_KEY_BASE=CHANGE_ME_staging_secret_64_chars_minimum_generate_with_mix_phx_gen_secret

# === Dashboard ===
ADMIN_PASSWORD=CHANGE_ME_staging_admin

# === Grafana ===
GRAFANA_PASSWORD=CHANGE_ME_staging_grafana

# === Optional ===
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
