# Model Hunter — API keys and secrets
# Copy to .env and fill in your keys. Never commit .env.
#
# Required for generation (OpenRouter models like GPT-5.2, Claude, Qwen):
OPENROUTER_API_KEY=sk-or-v1-your-key-here
#
# Required for judge/evaluation:
OPENAI_API_KEY=sk-your-openai-key-here
#
# Optional (if using Fireworks models):
# FIREWORKS_API_KEY=your-fireworks-key
#
# Optional (Docker sets REDIS_URL automatically):
# REDIS_URL=redis://redis:6379/0

# PostgreSQL (Docker sets these automatically):
# DATABASE_URL=postgresql+asyncpg://mh:mh_dev@localhost:5432/model_hunter
