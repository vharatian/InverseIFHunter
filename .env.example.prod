# Model Hunter — Production Environment Variables
# Copy to .env and fill in all values before deploying.

# === Domain ===
DOMAIN=your-domain.example.com
ACME_EMAIL=admin@example.com

# === API Keys (required) ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
# FIREWORKS_API_KEY=your-fireworks-key

# === PostgreSQL ===
PG_USER=mh
PG_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://mh:CHANGE_ME_strong_password_here@postgres:5432/model_hunter

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Elixir ===
ELIXIR_SECRET_KEY_BASE=CHANGE_ME_generate_with_mix_phx_gen_secret

# === Dashboard ===
ADMIN_PASSWORD=CHANGE_ME_admin_password

# === Grafana ===
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# === Optional ===
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/workspace/service_account.json
